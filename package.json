{
  "name": "dataq-analyzer-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "User frontend for DataQ Analyzer - MQTT-based analyzer for Axis DataQ camera path and flow data",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "docker:build": "docker build --build-arg VITE_API_URL=http://localhost:3000 -t dataq-frontend -f docker/Dockerfile .",
    "docker:run": "docker run -d -p 80:80 --name dataq-frontend dataq-frontend",
    "docker:stop": "docker stop dataq-frontend && docker rm dataq-frontend",
    "lint": "eslint ."
  },
  "dependencies": {
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
