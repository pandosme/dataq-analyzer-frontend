{
  "name": "dataq-analyzer-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "User frontend for DataQ Analyzer - MQTT-based analyzer for Axis DataQ camera path and flow data",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "docker:build": "docker build -t pandosme/dataq-frontend:latest -f docker/Dockerfile .",
    "docker:push": "docker push pandosme/dataq-frontend:latest",
    "docker:build-push": "npm run docker:build && npm run docker:push",
    "docker:run": "docker run -d -p 8303:80 -e BACKEND_URL=http://host.docker.internal:3303 --name dataq-frontend pandosme/dataq-frontend:latest",
    "docker:stop": "docker stop dataq-frontend && docker rm dataq-frontend"
  },
  "dependencies": {
    "axios": "^1.13.2",
    "date-fns": "^4.1.0",
    "prop-types": "^15.8.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/react": "^19.2.5",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "vite": "^7.2.4"
  }
}
